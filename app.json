{
  "expo": {
    "name": "Marina IA",
    "slug": "marina-ia",
    "version": "1.0.0",
    "platforms": [
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#131314"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#131314"
      },
      "package": "com.deywd.marinaia",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/67dd5514-4060-4cc9-8ac6-eaaa5ee21c16"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "67dd5514-4060-4cc9-8ac6-eaaa5ee21c16"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-haptics",
      "expo-updates",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para que a Marina possa analisá-las.",
          "cameraPermission": "O app precisa acessar sua câmera para que a Marina possa ver o mundo."
        }
      ]
    ]
  }
}
